{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:duabackendserver.database.windows.net,1433;Initial Catalog=DuaBusiness;Persist Security Info=False;User ID={admin};Password={password};MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "AzureKeyVault": {
    "VaultUrl": "https://duabusiness-kv.vault.azure.net/"
  },
  "ApplicationInsights": {
    "InstrumentationKey": "{instrumentation-key}"
  },
  "AzureServiceBus": {
    "ConnectionString": "{service-bus-connection-string}"
  },
  "AzureStorage": {
    "ConnectionString": "{storage-connection-string}",
    "ContainerNames": {
      "FileUploads": "file-uploads",
      "Templates": "templates",
      "GeneratedDocuments": "generated-documents"
    }
  }
}
